// Supabase Postgres + Prisma
// Auth.js v5 兼容 + 邮箱注册 + 验证码

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── 用户 ─────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  membership       Membership?
  resourceClaims   ResourceClaim[]
  serviceRequests  ServiceRequest[]
  orders           Order[]
  couponClaims     CouponClaim[]
  couponUsages     CouponUsage[]
  redeemCodeUsages RedeemCodeUsage[]
  checkins         Checkin[]
  livingDiagnoses  LivingDiagnosis[]

  @@map("users")
}

// ─── OAuth 账号关联（Google 等）─────────────────────────────
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

// ─── Session（Auth.js 需要，JWT 模式下基本不写入）──────────
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

// ─── Auth.js 验证令牌（内部用，非邮箱验证码）──────────────
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── 邮箱验证码（注册 / 重置密码 / 修改密码）──────────────
model VerificationCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  type       String // register | reset_password | change_password
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, type])
  @@map("verification_codes")
}

// ─── 会员资格 ───────────────────────────────────────────────
model Membership {
  id        String    @id @default(cuid())
  userId    String    @unique
  plan      String    @default("free") // free | creator
  status    String    @default("active") // active | expired | cancelled
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

// ─── 资料领取记录 ───────────────────────────────────────────
model ResourceClaim {
  id            String   @id @default(cuid())
  userId        String
  resourceId    String
  resourceTitle String
  resourceUrl   String?
  claimedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resource_claims")
}

// ─── 服务申请记录 ───────────────────────────────────────────
model ServiceRequest {
  id          String   @id @default(cuid())
  userId      String?
  serviceType String
  name        String?
  phone       String?
  wechat      String?
  email       String?
  message     String?
  status      String   @default("submitted") // submitted | reviewing | completed | rejected
  aiCategory  String?  // AI 分类：quote_review / contract_review / living_diagnosis / budget / general
  responseText String? // 最终回复文本
  reviewedAt  DateTime?
  savedToKnowledge Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("service_requests")
}

// ─── 商品 ────────────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  name        String
  type        String // digital_resource | membership | consulting | service | course
  price       Int // 分
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@map("products")
}

// ─── 订单 ────────────────────────────────────────────────────
model Order {
  id             String    @id @default(cuid())
  userId         String?
  orderNo        String    @unique
  productId      String?
  productName    String
  productType    String
  amount         Int // 原价（分）
  discountAmount Int       @default(0)
  paidAmount     Int
  status         String    @default("pending") // pending|paid|processing|completed|cancelled|refunded
  paymentMethod  String? // wechat|alipay|manual
  couponId       String?
  redeemCodeId   String?
  source         String?
  remark         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  paidAt         DateTime?
  completedAt    DateTime?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  product  Product?  @relation(fields: [productId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// ─── 支付记录 ────────────────────────────────────────────────
model Payment {
  id            String   @id @default(cuid())
  orderId       String
  amount        Int
  method        String // wechat|alipay|manual
  status        String   @default("pending") // pending|success|failed
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

// ─── 优惠券 ──────────────────────────────────────────────────
model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  type      String // fixed | percent
  value     Int // 固定减（分）或折扣（0-100 表示折扣百分比）
  minAmount Int       @default(0)
  maxUses   Int? // null = 不限
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  claims CouponClaim[]
  usages CouponUsage[]

  @@map("coupons")
}

model CouponClaim {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  claimedAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@map("coupon_claims")
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  orderId  String?
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coupon_usages")
}

// ─── 兑换码 ──────────────────────────────────────────────────
model RedeemCode {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String // membership | resource | coupon | service_discount
  value     String? // plan name / resource id / coupon code / discount amount
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  usages RedeemCodeUsage[]

  @@map("redeem_codes")
}

model RedeemCodeUsage {
  id           String   @id @default(cuid())
  redeemCodeId String
  userId       String
  usedAt       DateTime @default(now())

  redeemCode RedeemCode @relation(fields: [redeemCodeId], references: [id])
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([redeemCodeId, userId])
  @@map("redeem_code_usages")
}

// ─── 行为事件 ────────────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  path      String?
  referrer  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─── 每日汇总指标 ─────────────────────────────────────────────
model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime @unique
  pageViews       Int      @default(0)
  uniqueUsers     Int      @default(0)
  newUsers        Int      @default(0)
  logins          Int      @default(0)
  resourceClaims  Int      @default(0)
  serviceRequests Int      @default(0)
  orderCount      Int      @default(0)
  orderRevenue    Int      @default(0) // 分
  memberCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("daily_metrics")
}

// ─── 签到打卡 ────────────────────────────────────────────────
model Checkin {
  id        String   @id @default(cuid())
  userId    String
  checkedAt DateTime @default(now())
  note      String?
  streak    Int      @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([checkedAt])
  @@map("checkins")
}

// ─── 思考札记 ─────────────────────────────────────────────────
// visibility 控制前台展示权限：
//   PUBLIC  → 前台可见
//   PRIVATE → 仅管理员登录后可见
//   DRAFT   → 仅后台可见，前台完全屏蔽
enum NoteVisibility {
  PUBLIC
  PRIVATE
  DRAFT
}

model Note {
  id         String         @id @default(cuid())
  title      String
  slug       String         @unique
  excerpt    String?
  content    String
  category   String?
  tags       String[]
  visibility NoteVisibility @default(DRAFT)
  featured   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([visibility])
  @@index([createdAt])
  @@map("notes")
}

// ─── 内容中台推送的网站草稿 ─────────────────────────────────────
// 只用于承接 Feishu/Hermes/CLI 推送过来的草稿，不直接发布到前台。
model WebsiteContentDraft {
  id              String    @id @default(cuid())
  contentId       String    @unique
  briefId         String?
  topicId         String?
  title           String
  slug            String
  excerpt         String?
  content         String
  platform        String    @default("website")
  status          String    @default("draft") // draft | staged | approved | returned | published | archived
  approvalStatus  String    @default("pending") // pending | approved | returned
  reviewScore     Int?
  qualitySummary  String?
  source          String    @default("content_hub")
  adapterId       String?
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  previewPath     String?
  publishedUrl    String?
  payload         Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  stagedAt        DateTime?
  approvedAt      DateTime?
  publishedAt     DateTime?

  @@index([briefId])
  @@index([slug])
  @@index([status])
  @@index([approvalStatus])
  @@index([createdAt])
  @@map("website_content_drafts")
}

// ─── AI 居住诊断记录 ─────────────────────────────────────────
// 用于保存 /living-diagnosis 的公开诊断提交。
// 第一阶段只做本地规则分析 + 后台人工审核，不直接自动发布报告。
model LivingDiagnosis {
  id            String   @id @default(cuid())
  userId        String?
  source        String   @default("living_diagnosis_page")
  stage         String?
  city          String?
  homeType      String?
  area          String?
  budgetRange   String?
  contactName   String?
  contactWechat String?
  contactEmail  String?
  answers       Json
  result        Json?
  status        String   @default("submitted") // submitted | reviewing | report_draft | completed | archived
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  report DiagnosisReport?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("living_diagnoses")
}

// ─── 居住诊断报告草稿 ───────────────────────────────────────
// 付费报告和公开报告页的预留模型；本阶段只建结构，不开放前台报告页。
model DiagnosisReport {
  id          String    @id @default(cuid())
  diagnosisId String    @unique
  title       String
  status      String    @default("draft") // draft | reviewed | published | archived
  aiSummary   String?
  zenoReview  String?
  report      Json
  publicToken String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  diagnosis LivingDiagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("diagnosis_reports")
}

// ─── 后台操作日志 ─────────────────────────────────────────────
model AdminLog {
  id        String   @id @default(cuid())
  action    String
  target    String?
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("admin_logs")
}

// ─── 项目交付：工地管理 ───────────────────────────────────────
model Project {
  id          String    @id @default(cuid())
  name        String                    // 项目名称，如"张先生 南宁 120平"
  clientName  String?                   // 业主姓名
  clientPhone String?                   // 业主电话
  clientWechat String?                  // 业主微信
  city        String?                   // 城市
  address     String?                   // 详细地址
  area        Float?                    // 面积（㎡）
  budget      Int?                      // 装修预算（分）
  homeType    String?                   // 户型：毛坯/旧房翻新/精装修改造
  style       String?                   // 风格
  source      String?                   // 来源：网站/微信/转介绍/其他
  status      String    @default("active") // active | completed | paused | cancelled
  startedAt   DateTime?                 // 开工日期
  completedAt DateTime?                 // 竣工日期
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  nodes       ProjectNode[]
  photos      ProjectPhoto[]
  notes       ProjectNote[]

  @@index([status])
  @@index([createdAt])
  @@map("projects")
}

model ProjectNode {
  id          String    @id @default(cuid())
  projectId   String
  name        String                    // 节点名称：水电验收/防水验收/贴砖验收...
  sortOrder   Int       @default(0)     // 排序
  status      String    @default("pending") // pending | in_progress | submitted | reviewed | passed | failed
  scheduledAt DateTime?                 // 计划验收日期
  submittedAt DateTime?                 // 业主提交照片日期
  reviewedAt  DateTime?                 // Zeno 审核日期
  zenoFeedback String?                  // Zeno 的审核反馈
  result      String?                   // pass | fail | conditional
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  photos  ProjectPhoto[]

  @@index([projectId])
  @@index([status])
  @@map("project_nodes")
}

model ProjectPhoto {
  id        String   @id @default(cuid())
  projectId String
  nodeId    String?
  url       String
  caption   String?
  takenAt   DateTime?
  createdAt DateTime @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  node    ProjectNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([nodeId])
  @@map("project_photos")
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  content   String
  type      String   @default("general") // general | client_comm | change_order | settlement
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@map("project_notes")
}

// ─── AI 知识库 ───────────────────────────────────────────────
model KnowledgeEntry {
  id        String   @id @default(cuid())
  title     String                     // 标题，如"装修预算合理区间参考"
  category  String                     // 分类：budget | effect | pitfall | quote | contract | process | material | other
  content   String                     // 知识正文（Markdown）
  tags      String[]                   // 标签
  priority  Int      @default(0)       // 排序权重，越高越靠前
  isActive  Boolean  @default(true)    // 是否启用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("knowledge_entries")
}
