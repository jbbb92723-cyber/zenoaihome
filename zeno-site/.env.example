
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# IDC Flare OAuth 配置
# 在 IDC Flare 开发者后台创建应用后获取以下信息
IDCFLARE_CLIENT_ID=
IDCFLARE_CLIENT_SECRET=
IDCFLARE_ISSUER=
IDCFLARE_AUTHORIZATION_URL=
IDCFLARE_TOKEN_URL=
IDCFLARE_USERINFO_URL=

# 数据库连接（Supabase Postgres）
# 在 Supabase 项目 Settings → Database → Connection string 中获取
DATABASE_URL=

# 站点 URL（用于回调地址等）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# 公众号草稿 & AI 封面图功能
# ─────────────────────────────────────────────────────────────────

# md2wechat：Markdown → 微信公众号 HTML 转换 & 草稿创建
# API Key 购买后在 md2wechat.cn 控制台获取
MD2WECHAT_API_KEY=
# md2wechat API 服务地址（填写 Host，不带末尾斜杠，不带 /api/v1/...）
# 例如：https://md2wechat.cn 或 https://md2wechat.app
MD2WECHAT_BASE_URL=

# 微信公众号：AppID 和 AppSecret
# 获取：微信公众平台 → 设置与开发 → 基本配置
WECHAT_APPID=
WECHAT_APP_SECRET=
WECHAT_DEFAULT_AUTHOR=Zeno
# 默认封面图 media_id（在微信公众号素材库上传图片后获取）
WECHAT_DEFAULT_COVER_MEDIA_ID=

# 火山引擎豆包图片生成
# API Key 在：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLCENGINE_ARK_API_KEY=
# 模型 ID（不写死，从控制台确认后填入）
# 例如：doubao-seedream-3-0-t2i-250415
VOLCENGINE_IMAGE_MODEL=
# API 基础地址（默认不用改）
VOLCENGINE_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 单张图片预估成本（元），用于前端显示，不影响实际计费
VOLCENGINE_IMAGE_PRICE_PER_IMAGE=0.22
# 前端显示用（不含密钥）
NEXT_PUBLIC_IMAGE_PRICE=0.22

# 管理员邮箱（逗号分隔），拥有草稿推送和图片生成权限
# 例如：admin@example.com,other@example.com
ADMIN_EMAILS=

# 后台管理 Token（保护旧版 /admin/publish 页面）
ADMIN_TOKEN=
