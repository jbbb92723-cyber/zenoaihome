
# ═══════════════════════════════════════════════
# Zeno AI Home — 环境变量配置模板
# 复制此文件为 .env.local，填入真实值（.env.local 绝不提交到 git）
# ═══════════════════════════════════════════════

# ── Auth 基础 ──────────────────────────────────
AUTH_SECRET=                    # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ── Supabase Postgres（从 Supabase 控制台 → Settings → Database 获取）──
# DATABASE_URL：使用 Supabase Pooler 连接（Transaction mode，端口 6543）
DATABASE_URL=
# DIRECT_URL：使用直连（用于 prisma db push / migrations，端口 5432）
DIRECT_URL=

# ── Google 登录（Google Cloud Console 获取）──
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── 邮件验证码（Resend.com 获取）──
RESEND_API_KEY=
EMAIL_FROM=Zeno <noreply@zenoaihome.com>

# ── 管理员后台（独立于用户登录）──
ADMIN_PASSWORD=                 # 自定义强密码
ADMIN_SESSION_SECRET=           # openssl rand -base64 32

# ── 内容中台 / Hermes / CLI 内部 API ──
# 用于 Authorization: Bearer <token> 调用 /api/internal/*
ZENO_INTERNAL_API_TOKEN=        # openssl rand -base64 32

# ── md2wechat 排版 API ──
MD2WECHAT_BASE_URL=
MD2WECHAT_API_KEY=
MD2WECHAT_CONVERT_ENDPOINT=
MD2WECHAT_DRAFT_ENDPOINT=
MD2WECHAT_UPLOAD_ENDPOINT=

# ── 微信公众号草稿箱 ──
WECHAT_APPID=
WECHAT_APP_SECRET=
WECHAT_DEFAULT_AUTHOR=Zeno
WECHAT_DEFAULT_COVER_MEDIA_ID=

# ── 豆包图片生成（火山引擎）──
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_IMAGE_MODEL=Doubao-Seedream-5.0-lite
VOLCENGINE_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_IMAGE_PRICE_PER_IMAGE=0.22

# ── 站点 URL ──
NEXT_PUBLIC_SITE_URL=https://zenoaihome.com
