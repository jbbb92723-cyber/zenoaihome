// Supabase Postgres + Prisma
// Auth.js v5 兼容 + 邮箱注册 + 验证码

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── 用户 ─────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  membership        Membership?
  resourceClaims    ResourceClaim[]
  serviceRequests   ServiceRequest[]
  orders            Order[]
  couponClaims      CouponClaim[]
  couponUsages      CouponUsage[]
  redeemCodeUsages  RedeemCodeUsage[]
  checkins          Checkin[]

  @@map("users")
}

// ─── OAuth 账号关联（Google 等）─────────────────────────────
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

// ─── Session（Auth.js 需要，JWT 模式下基本不写入）──────────
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

// ─── Auth.js 验证令牌（内部用，非邮箱验证码）──────────────
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── 邮箱验证码（注册 / 重置密码 / 修改密码）──────────────
model VerificationCode {
  id         String   @id @default(cuid())
  email      String
  codeHash   String
  type       String   // register | reset_password | change_password
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([email, type])
  @@map("verification_codes")
}

// ─── 会员资格 ───────────────────────────────────────────────
model Membership {
  id        String    @id @default(cuid())
  userId    String    @unique
  plan      String    @default("free")   // free | creator
  status    String    @default("active") // active | expired | cancelled
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

// ─── 资料领取记录 ───────────────────────────────────────────
model ResourceClaim {
  id            String   @id @default(cuid())
  userId        String
  resourceId    String
  resourceTitle String
  resourceUrl   String?
  claimedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resource_claims")
}

// ─── 服务申请记录 ───────────────────────────────────────────
model ServiceRequest {
  id          String   @id @default(cuid())
  userId      String?
  serviceType String
  name        String?
  phone       String?
  wechat      String?
  email       String?
  message     String?
  status      String   @default("submitted") // submitted | reviewing | completed | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("service_requests")
}

// ─── 商品 ────────────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  name        String
  type        String   // digital_resource | membership | consulting | service | course
  price       Int      // 分
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@map("products")
}

// ─── 订单 ────────────────────────────────────────────────────
model Order {
  id             String    @id @default(cuid())
  userId         String?
  orderNo        String    @unique
  productId      String?
  productName    String
  productType    String
  amount         Int       // 原价（分）
  discountAmount Int       @default(0)
  paidAmount     Int
  status         String    @default("pending") // pending|paid|processing|completed|cancelled|refunded
  paymentMethod  String?   // wechat|alipay|manual
  couponId       String?
  redeemCodeId   String?
  source         String?
  remark         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  paidAt         DateTime?
  completedAt    DateTime?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  product  Product?  @relation(fields: [productId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// ─── 支付记录 ────────────────────────────────────────────────
model Payment {
  id            String   @id @default(cuid())
  orderId       String
  amount        Int
  method        String   // wechat|alipay|manual
  status        String   @default("pending") // pending|success|failed
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

// ─── 优惠券 ──────────────────────────────────────────────────
model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  type      String    // fixed | percent
  value     Int       // 固定减（分）或折扣（0-100 表示折扣百分比）
  minAmount Int       @default(0)
  maxUses   Int?      // null = 不限
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  claims CouponClaim[]
  usages CouponUsage[]

  @@map("coupons")
}

model CouponClaim {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  claimedAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@map("coupon_claims")
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  orderId  String?
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coupon_usages")
}

// ─── 兑换码 ──────────────────────────────────────────────────
model RedeemCode {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    // membership | resource | coupon | service_discount
  value     String?   // plan name / resource id / coupon code / discount amount
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  usages RedeemCodeUsage[]

  @@map("redeem_codes")
}

model RedeemCodeUsage {
  id           String   @id @default(cuid())
  redeemCodeId String
  userId       String
  usedAt       DateTime @default(now())

  redeemCode RedeemCode @relation(fields: [redeemCodeId], references: [id])
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([redeemCodeId, userId])
  @@map("redeem_code_usages")
}

// ─── 行为事件 ────────────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  path      String?
  referrer  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─── 每日汇总指标 ─────────────────────────────────────────────
model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime @unique
  pageViews       Int      @default(0)
  uniqueUsers     Int      @default(0)
  newUsers        Int      @default(0)
  logins          Int      @default(0)
  resourceClaims  Int      @default(0)
  serviceRequests Int      @default(0)
  orderCount      Int      @default(0)
  orderRevenue    Int      @default(0) // 分
  memberCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("daily_metrics")
}

// ─── 签到打卡 ────────────────────────────────────────────────
model Checkin {
  id        String   @id @default(cuid())
  userId    String
  checkedAt DateTime @default(now())
  note      String?
  streak    Int      @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([checkedAt])
  @@map("checkins")
}

// ─── 思考札记 ─────────────────────────────────────────────────
// visibility 控制前台展示权限：
//   PUBLIC  → 前台可见
//   PRIVATE → 仅管理员登录后可见
//   DRAFT   → 仅后台可见，前台完全屏蔽
enum NoteVisibility {
  PUBLIC
  PRIVATE
  DRAFT
}

model Note {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  excerpt     String?
  content     String
  category    String?
  tags        String[]
  visibility  NoteVisibility @default(DRAFT)
  featured    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([visibility])
  @@index([createdAt])
  @@map("notes")
}

// ─── 后台操作日志 ─────────────────────────────────────────────
model AdminLog {
  id        String   @id @default(cuid())
  action    String
  target    String?
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("admin_logs")
}
